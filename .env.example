# Copy to .env and fill in values

# LLM provider — set ONE of the following:
OPENAI_API_KEY=
# GROQ_API_KEY=          # free tier at https://console.groq.com
# OPENROUTER_API_KEY=    # free models at https://openrouter.ai

# Optional overrides
# LLM_PROVIDER=openai      # openai | groq | openrouter
# LLM_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# RAG settings
# CORPUS_DIR=corpus
# CHROMA_DIR=chroma_db
# TOP_K=4
# MIN_RELEVANCE_SCORE=0.25
# MAX_RESPONSE_WORDS=300
